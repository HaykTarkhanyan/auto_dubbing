# At least one translation provider API key is required
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Optional: override defaults
TRANSLATION_PROVIDER=claude          # claude | gemini
TTS_PROVIDER=gemini                  # gemini | edge_tts
TTS_VOICE_NAME=Kore                  # See full list in modules/tts.py
WHISPER_MODEL_SIZE=base
MAX_SPEED_FACTOR=1.35
MIN_SPEED_FACTOR=0.75
